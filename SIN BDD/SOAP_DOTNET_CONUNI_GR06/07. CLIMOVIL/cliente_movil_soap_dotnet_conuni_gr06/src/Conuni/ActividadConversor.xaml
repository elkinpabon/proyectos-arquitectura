<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ec.Edu.Monster.Conuni.ActividadConversor"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource ConuniGrisFondo}">
    <Grid RowDefinitions="56,*">
        <Grid BackgroundColor="{StaticResource ConuniAzul}" Padding="12,0" ColumnDefinitions="Auto,*">
            <Button Text="←" Clicked="Volver_Clicked" BackgroundColor="Transparent" TextColor="White" FontSize="20" WidthRequest="44" HeightRequest="44" />
            <Label x:Name="TituloCategoria" Grid.Column="1" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <Frame WidthRequest="72" HeightRequest="72" CornerRadius="12" BackgroundColor="White" BorderColor="{StaticResource ConuniAmarillo}" Padding="0" HasShadow="False">
                        <Label x:Name="IconoCategoria" TextColor="{StaticResource ConuniAzul}" FontSize="40" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label x:Name="TituloConversion" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource ConuniAzul}" />
                        <Label x:Name="DescripcionCategoria" FontSize="13" TextColor="Gray" />
                    </VerticalStackLayout>
                </Grid>

                <Picker x:Name="SelectorConversion" Title="Conversion" TextColor="Black" BackgroundColor="White" />
                <Entry x:Name="EntradaValor" Placeholder="Valor" Keyboard="Numeric" BackgroundColor="White" TextColor="Black" />
                <Button Text="Convertir" Clicked="Convertir_Clicked" BackgroundColor="{StaticResource ConuniAzul}" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" />

                <Frame x:Name="CajaResultado" IsVisible="False" CornerRadius="8" Padding="14" HasShadow="False">
                    <Label x:Name="EtiquetaResultado" FontAttributes="Bold" />
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
