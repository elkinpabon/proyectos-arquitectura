@model Ec.Edu.Monster.Modelo.Resultado
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Conversiones de Longitud - CONUNI</title>
    <link rel="stylesheet" href="~/css/estilo.css">
</head>
<body>
    <div class="encabezado">
        <h1>
            <img class="logo" src="~/img/moster.webp" alt="Logo CONUNI">
            Cliente Web CONUNI
        </h1>
        <div>
            <a href="/ControladorMenu/Index">Menu</a>
            &nbsp;|&nbsp;
            <form action="/ControladorCerrarSesion/CerrarSesion" method="post" style="display:inline;">
                <button type="submit" class="enlace-boton">Cerrar Sesion</button>
            </form>
        </div>
    </div>

    <div class="contenedor">
        <div class="conversion-encabezado">
            <svg viewBox="0 0 24 24" fill="#1f3a5f" width="64" height="64" style="border-radius:12px;border:3px solid #ffd966;padding:6px;background:#fffbe6;">
                <path d="M21 6H3c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h18c.55 0 1-.45 1-1V7c0-.55-.45-1-1-1zm-1 10H4V8h2v4h2V8h2v4h2V8h2v4h2V8h2v4h2v4z"/>
            </svg>
            <div>
                <h2>Conversiones de Longitud</h2>
                <p>Convierte entre metros, pies, kilometros, millas, pulgadas y mas.</p>
            </div>
        </div>

        <form action="/ControladorLongitud/Index" method="post">
            <label for="operacion">Conversion:</label>
            <select id="operacion" name="operacion" required>
                @if (ViewBag.OperacionSeleccionada == "metrosAPies") { <option value="metrosAPies" selected>Metros a Pies</option> } else { <option value="metrosAPies">Metros a Pies</option> }
                @if (ViewBag.OperacionSeleccionada == "kilometrosAMillas") { <option value="kilometrosAMillas" selected>Kilometros a Millas</option> } else { <option value="kilometrosAMillas">Kilometros a Millas</option> }
                @if (ViewBag.OperacionSeleccionada == "centimetrosAPulgadas") { <option value="centimetrosAPulgadas" selected>Centimetros a Pulgadas</option> } else { <option value="centimetrosAPulgadas">Centimetros a Pulgadas</option> }
                @if (ViewBag.OperacionSeleccionada == "yardasAMetros") { <option value="yardasAMetros" selected>Yardas a Metros</option> } else { <option value="yardasAMetros">Yardas a Metros</option> }
                @if (ViewBag.OperacionSeleccionada == "milimetrosAPulgadas") { <option value="milimetrosAPulgadas" selected>Milimetros a Pulgadas</option> } else { <option value="milimetrosAPulgadas">Milimetros a Pulgadas</option> }
            </select>

            <label for="valor">Valor:</label>
            <input type="number" step="any" id="valor" name="valor" value="@ViewBag.ValorIngresado" required>

            <button type="submit">Convertir</button>
        </form>

        @if (Model is not null)
        {
            if (Model.Exito)
            {
                <div class="mensaje-exito">Resultado: @Model.Valor</div>
            }
            else
            {
                <div class="mensaje-error">@Model.Mensaje</div>
            }
        }
    </div>
</body>
</html>
