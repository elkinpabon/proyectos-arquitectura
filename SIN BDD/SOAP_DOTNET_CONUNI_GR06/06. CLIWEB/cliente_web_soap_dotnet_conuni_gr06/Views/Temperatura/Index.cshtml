@model Ec.Edu.Monster.Modelo.Resultado
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Conversiones de Temperatura - CONUNI</title>
    <link rel="stylesheet" href="~/css/estilo.css">
</head>
<body>
    <div class="encabezado">
        <h1>
            <img class="logo" src="~/img/moster.webp" alt="Logo CONUNI">
            Cliente Web CONUNI
        </h1>
        <div>
            <a href="/ControladorMenu/Index">Menu</a>
            &nbsp;|&nbsp;
            <form action="/ControladorCerrarSesion/CerrarSesion" method="post" style="display:inline;">
                <button type="submit" class="enlace-boton">Cerrar Sesion</button>
            </form>
        </div>
    </div>

    <div class="contenedor">
        <div class="conversion-encabezado">
            <svg viewBox="0 0 24 24" fill="#1f3a5f" width="64" height="64" style="border-radius:12px;border:3px solid #ffd966;padding:6px;background:#fffbe6;">
                <path d="M15 13V5c0-1.66-1.34-3-3-3S9 3.34 9 5v8c-1.21.91-2 2.37-2 4 0 2.76 2.24 5 5 5s5-2.24 5-5c0-1.63-.79-3.09-2-4zm-4-8c0-.55.45-1 1-1s1 .45 1 1h-1v1h1v2h-1v1h1v2h-2V5z"/>
            </svg>
            <div>
                <h2>Conversiones de Temperatura</h2>
                <p>Convierte entre Celsius, Fahrenheit y Kelvin.</p>
            </div>
        </div>

        <form action="/ControladorTemperatura/Index" method="post">
            <label for="operacion">Conversion:</label>
            <select id="operacion" name="operacion" required>
                @if (ViewBag.OperacionSeleccionada == "celsiusAFahrenheit") { <option value="celsiusAFahrenheit" selected>Celsius a Fahrenheit</option> } else { <option value="celsiusAFahrenheit">Celsius a Fahrenheit</option> }
                @if (ViewBag.OperacionSeleccionada == "fahrenheitACelsius") { <option value="fahrenheitACelsius" selected>Fahrenheit a Celsius</option> } else { <option value="fahrenheitACelsius">Fahrenheit a Celsius</option> }
                @if (ViewBag.OperacionSeleccionada == "celsiusAKelvin") { <option value="celsiusAKelvin" selected>Celsius a Kelvin</option> } else { <option value="celsiusAKelvin">Celsius a Kelvin</option> }
                @if (ViewBag.OperacionSeleccionada == "kelvinACelsius") { <option value="kelvinACelsius" selected>Kelvin a Celsius</option> } else { <option value="kelvinACelsius">Kelvin a Celsius</option> }
                @if (ViewBag.OperacionSeleccionada == "fahrenheitAKelvin") { <option value="fahrenheitAKelvin" selected>Fahrenheit a Kelvin</option> } else { <option value="fahrenheitAKelvin">Fahrenheit a Kelvin</option> }
            </select>

            <label for="valor">Valor:</label>
            <input type="number" step="any" id="valor" name="valor" value="@ViewBag.ValorIngresado" required>

            <button type="submit">Convertir</button>
        </form>

        @if (Model is not null)
        {
            if (Model.Exito)
            {
                <div class="mensaje-exito">Resultado: @Model.Valor</div>
            }
            else
            {
                <div class="mensaje-error">@Model.Mensaje</div>
            }
        }
    </div>
</body>
</html>
