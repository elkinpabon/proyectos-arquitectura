<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ec.Edu.Monster.Vista.ActividadPrincipal"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource ConuniGrisFondo}">
    <Grid RowDefinitions="56,*">
        <Grid BackgroundColor="{StaticResource ConuniAzul}" Padding="20,0" ColumnDefinitions="Auto,*">
            <Image Source="moster.webp" HeightRequest="34" WidthRequest="34" Aspect="AspectFill" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="Cliente Movil CONUNI" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center" MaximumWidthRequest="420">
                <Image Source="moster.webp" HeightRequest="110" WidthRequest="110" Aspect="AspectFit" HorizontalOptions="Center" />
                <Label Text="Iniciar Sesion" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource ConuniAzul}" HorizontalTextAlignment="Center" />
                <Label Text="Ingresa tus credenciales" FontSize="13" TextColor="Gray" HorizontalTextAlignment="Center" />

                <Frame Padding="0" CornerRadius="12" HasShadow="True" BackgroundColor="White">
                    <Image Source="login.jpg" HeightRequest="160" Aspect="AspectFill" />
                </Frame>

                <Entry x:Name="EntradaUsuario" Placeholder="Usuario" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry x:Name="EntradaContrasena" Placeholder="Contrasena" IsPassword="True" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray" />
                    <Button x:Name="BotonContrasena" Grid.Column="1" Text="Mostrar" BackgroundColor="{StaticResource ConuniAzulClaro}" TextColor="White" />
                </Grid>

                <Button x:Name="BotonIngresar" Text="Ingresar" BackgroundColor="{StaticResource ConuniAzul}" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" />

                <ActivityIndicator x:Name="IndicadorCargando" IsVisible="False" IsRunning="False" Color="{StaticResource ConuniAzul}" />
                <Label x:Name="EtiquetaEstado" Text=" " FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
