<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClienteMovilConuni">

        <activity
            android:name=".vista.LoginActivity"
            android:exported="true"
            android:label="@string/titulo_login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".vista.MenuActivity"
            android:exported="false"
            android:label="@string/titulo_menu"
            android:parentActivityName=".vista.LoginActivity" />

        <activity
            android:name=".vista.LongitudActivity"
            android:exported="false"
            android:label="@string/titulo_longitud"
            android:parentActivityName=".vista.MenuActivity" />

        <activity
            android:name=".vista.MasaActivity"
            android:exported="false"
            android:label="@string/titulo_masa"
            android:parentActivityName=".vista.MenuActivity" />

        <activity
            android:name=".vista.TemperaturaActivity"
            android:exported="false"
            android:label="@string/titulo_temperatura"
            android:parentActivityName=".vista.MenuActivity" />

    </application>

</manifest>
